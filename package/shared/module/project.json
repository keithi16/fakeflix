{
  "name": "shared-module",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "package/shared/module",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project typeorm --web",
  "targets": {
    "lint:check": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["package/shared/module/**/*.ts"]
      }
    },
    "lint:fix": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["package/shared/module/**/*.ts"],
        "fix": true
      }
    }
  }
}
