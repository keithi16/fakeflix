{
  "name": "identity",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "package/identity",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project subscription --web",
  "targets": {
    "lint:check": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["package/identity/**/*.ts"]
      }
    },
    "lint:fix": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["package/identity/**/*.ts"],
        "fix": true
      }
    },
    "test:unit": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "package/identity/jest.config.ts",
        "passWithNoTests": true,
        "testMatch": ["<rootDir>/**/unit/**/*.spec.ts"]
      }
    },
    "test:e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "package/identity/jest.config.ts",
        "passWithNoTests": true,
        "testMatch": ["<rootDir>/**/e2e/**/*.spec.ts"],
        "runInBand": true
      }
    },
    "db:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node -r tsconfig-paths/register -P {projectRoot}/tsconfig.lib.json ./node_modules/typeorm/cli.js migration:generate {projectRoot}/persistence/migration/migration",
        "args": ["-d {projectRoot}/persistence/typeorm-datasource.ts"]
      }
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node -r tsconfig-paths/register -P {projectRoot}/tsconfig.lib.json ./node_modules/typeorm/cli.js migration:run",
        "args": ["-d {projectRoot}/persistence/typeorm-datasource.ts"]
      }
    },
    "db:drop": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node -r tsconfig-paths/register -P {projectRoot}/tsconfig.lib.json ./node_modules/typeorm/cli.js schema:drop",
        "args": ["-d {projectRoot}/persistence/typeorm-datasource.ts"]
      }
    }
  }
}
