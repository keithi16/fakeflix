  "scripts": {
    "db:generate:all": "nx run-many --target=db:generate --all",
    "db:migrate:all": "nx run-many --target=db:migrate --all",
    "db:drop:all": "nx run-many --target=db:drop --all",
    "streaming:db:setup": "yarn db:migrate:all",
    "docker:stop": "docker-compose stop",
    "docker:up": "docker-compose up --detach",
    "lint:all": "nx run-many --target=lint:check --all",
    "lint:fix:all": "nx run-many --target=lint:fix --all",
    "test:all": "yarn test:unit:all && yarn test:e2e:all",
    "test:affected": "yarn test:unit:affected && yarn test:e2e:affected",
    "test:unit:all": "nx run-many --target=test:unit --all",
    "test:unit:affected": "nx affected --target=test:unit",
    "test:e2e:all": "nx run-many --target=test:e2e --all --parallel=3",
    "test:e2e:affected": "nx affected --target=test:e2e --parallel=false",
    "release": "standard-version"
  },
  "engines": {
    "npm": "please-use-npm",
    "yarn": "^1.22"
  },
