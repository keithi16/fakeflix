{
  "name": "fakeflix",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "docker:stop": "docker-compose stop",
    "docker:up": "docker-compose up --detach",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' './*.{js,json}'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' './*.{js,json}'",
    "lint": "eslint '{src,apps,libs,test}/**/*.ts' --fix",
    "lint:check": "eslint '{src,apps,libs,test}/**/*.ts'",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "npm run test:type && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:db:migrate": "dotenv -e .env.test -- prisma db push",
    "test:e2e": "jest --runInBand --config ./test/jest.e2e.ts",
    "test:e2e:watch": "npm run test:e2e -- --watch",
    "test:integration": "jest --runInBand --config ./test/jest.integration.ts",
    "test:integration:watch": "npm run test:integration -- --watch",
    "test:type": "tsc --noEmit",
    "test:unit": "jest --config ./test/jest.unit.ts",
    "test:unit:watch": "npm run test:unit -- --watch",
    "identity:db:migrate": "prisma migrate dev",
    "identity:db:push": "prisma db push",
    "content-management:db:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate database/content/typeorm/migrations/migration  -d ./database/content/typeorm/migration.datasource.ts",
    "content-management:db:migrate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./database/content/typeorm/migration.datasource.ts"
  },
  "engines": {
    "npm": "please-use-npm",
    "yarn": "^1.22"
  },
  "dependencies": {
    "@apollo/server": "^4.7.5",
    "@nestjs/apollo": "^12.0.7",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/graphql": "^12.0.7",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.1",
    "@prisma/client": "^5.3.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "eslint-plugin-no-relative-import-paths": "^1.5.2",
    "fs-extra": "^11.1.1",
    "graphql": "^16.7.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.1",
    "@types/jest": "^29.5.2",
    "@types/jest-when": "^3.5.5",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "dotenv-cli": "^7.2.1",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "jest-when": "^3.6.0",
    "prettier": "^2.8.8",
    "prettier-plugin-organize-imports": "^3.2.3",
    "prisma": "^5.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "prisma": {
    "schema": "database/identity/prisma/schema.prisma"
  }
}
