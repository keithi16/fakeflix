# The .env.local file is used to store environment variables that are specific to your local machine. And is auto loaded by NX when running the app.
# This is used by TESTS and include all enviroment variables for all modules. When running apps each app has its enviornment file.
# ALWAYS RUN COMMANDS USING NX CLI
NODE_ENV=test

MONOLITH_API_PORT=3000

