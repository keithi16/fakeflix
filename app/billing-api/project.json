{
  "name": "billing-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "app/billing-api",
  "projectType": "application",
  "tags": ["app:billing-api"],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "development",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/app/billing-api",
        "main": "app/billing-api/main.ts",
        "tsConfig": "app/billing-api/tsconfig.app.json",
        "typeCheckOptions": false,
        "webpackConfig": "app/billing-api/webpack.config.js"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false
        }
      }
    },
    "start:dev": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "billing-api:build",
        "watch": true,
        "inspect": false,
        "runBuildTargetDependencies": false
      }
    },
    "start:debug": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "billing-api:build",
        "watch": true,
        "inspect": true
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "projects": "self"
        }
      ],
      "options": {
        "command": "node dist/app/billing-api/main.js"
      }
    },
    "lint:check": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["app/billing-api/**/*.ts"]
      }
    },
    "lint:fix": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["app/billing-api/**/*.ts"],
        "fix": true
      }
    }
  }
}
