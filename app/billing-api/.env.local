# The .env.local file is used to store environment variables that are specific to your local machine. And is auto loaded by NX when running the app.

NODE_ENV=development

BILLING_API_PORT=3001

BILLING_DATABASE_HOST=localhost
BILLING_DATABASE_PORT=5432
BILLING_DATABASE_USERNAME=postgres
BILLING_DATABASE_PASSWORD=postgres
BILLING_DATABASE_NAME=fakeflix_test
BILLING_DATABASE_URL=postgresql://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}