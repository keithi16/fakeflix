{
  "name": "monolith",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "app/monolith",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "development",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/app/monolith",
        "main": "app/monolith/main.ts",
        "tsConfig": "app/monolith/tsconfig.json",
        "webpackConfig": "app/monolith/webpack.config.js"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false
        }
      }
    },
    "start:dev": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "monolith:build",
        "watch": true,
        "inspect": false,
        "runBuildTargetDependencies": false
      }
    },
    "start:debug": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "monolith:build",
        "watch": true,
        "inspect": true
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "projects": "self"
        }
      ],
      "options": {
        "command": "node dist/app/monolith/main.js"
      }
    },
    "lint:check": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["app/monolith/**/*.ts"]
      }
    },
    "lint:fix": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["app/monolith/**/*.ts"],
        "fix": true
      }
    }
  }
}
