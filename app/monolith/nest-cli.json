{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": ".",
  "entryFile": "main",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.json",
    "assets": [
      {
        "include": "**/*.graphql",
        "outDir": "dist/app/monolith"
      }
    ],
    "watchAssets": true
  },
  "generateOptions": {
    "spec": true
  },
  "projects": {
    "monolith": {
      "type": "application",
      "root": "app/monolith",
      "entryFile": "main",
      "sourceRoot": ".",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    }
  }
}
