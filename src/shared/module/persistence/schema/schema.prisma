generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas = ["content", "identity", "test"]
}

model Video {
  id   String @id
  title String
  description String
  videoUrl String
  thumbnailUrl String?
  sizeInKb Int
  duration Int
  createdAt DateTime
  updatedAt DateTime

  @@schema("content")
}

model User {
  id String @id
  firstName String
  lastName String
  email String
  password String
  createdAt DateTime
  updatedAt DateTime

  @@unique([email])

  @@schema("identity")
}

model Test {
    id String @id
    someField String
    createdAt DateTime
    updatedAt DateTime

    @@schema("test")
}
